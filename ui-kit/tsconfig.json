{
    "compilerOptions": {
        "target": "es5",
        "module": "esnext", 
        "lib": ["dom", "esnext"],
        "declaration": true,
        "outDir": "./dist",
        "strict": true,
        "moduleResolution": "node",
        "jsx": "react-jsx", 
        "esModuleInterop": true,
        "skipLibCheck": true,
        "ignoreDeprecations": "6.0"
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}